# Production Environment Variables
# Copy this file to .env and fill in production values
# NEVER commit actual secrets - use Railway environment variables instead

# Application Environment
ENVIRONMENT=production

# Database Configuration
# In Railway: Use PostgreSQL service connection string
DATABASE_URL=postgresql://user:password@host:5432/servicemonks

# Security - IMPORTANT: Must be set to a long random string
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER use default or placeholder values in production
SECRET_KEY=<use-railway-secrets-to-fill-this>

# Authentication
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS - Set to your actual production domain(s)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email/SMTP - Gmail, SendGrid, or your email provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your-email@gmail.com>
SMTP_PASSWORD=<app-specific-password>
SMTP_FROM_NAME=Service Monks
NOTIFICATION_EMAIL=<internal-team-email@servicemonks.com>

# Business Configuration
RATE_PER_KM=5.0
MAX_SIGNATURE_SIZE_KB=500

# Optional: Cloud Storage (S3)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# S3_BUCKET=servicemonks-pdfs
