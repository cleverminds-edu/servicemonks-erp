# Application Environment
ENVIRONMENT=development

# Database Configuration
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/servicemonks

# Security - JWT Secret Key
# In production: use `python -c "import secrets; print(secrets.token_urlsafe(32))"`
# NEVER commit actual SECRET_KEY to version control
SECRET_KEY=your-long-random-secret-key-here-min-32-chars

# Authentication Token Settings
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Configuration - Allowed Origins
# Comma-separated list of allowed domains
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email/SMTP Configuration
# Leave blank to skip email sending in development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME=Service Monks Integrated Solutions
NOTIFICATION_EMAIL=

# Business Logic
RATE_PER_KM=5.0
MAX_SIGNATURE_SIZE_KB=500
